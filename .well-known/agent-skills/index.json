{
  "$schema": "https://skills.sh/schemas/agent-skills/index.schema.json",
  "version": "1.0",
  "skills": [
    {
      "name": "ifq-design-skills",
      "description": "Agent-native design engine that makes AI do more useful work: route the prompt, fork a template, weave IFQ ambient craft, verify the artifact, and only install export tooling when requested. One prompt -> shippable HTML, with optional MP4 / GIF / PPTX / PDF / SVG.",
      "files": [
        "SKILL.md"
      ],
      "metadata": {
        "version": "2.4.1",
        "category": "creative",
        "tags": [
          "design",
          "html",
          "prototype",
          "slides",
          "motion",
          "infographic",
          "dashboard",
          "brand",
          "pptx",
          "pdf",
          "svg",
          "mp4",
          "gif",
          "ifq",
          "agent-skills",
          "zero-install",
          "marketplace-ready"
        ],
        "platforms": [
          "macos",
          "linux",
          "windows"
        ],
        "license": "See LICENSE",
        "author": "ifq.ai",
        "homepage": "https://github.com/peixl/ifq-design-skills",
        "source": {
          "type": "github",
          "repo": "peixl/ifq-design-skills",
          "branch": "main"
        },
        "entrypoints": [
          "SKILL.md",
          "references/modes.md",
          "assets/templates/INDEX.json",
          "evals/evals.json"
        ],
        "human_value": [
          "turns vague design requests into finished HTML-first artifacts",
          "keeps export dependencies optional instead of making users set up heavy tooling",
          "documents verification so non-expert users can trust the result"
        ],
        "agent_value": [
          "short router plus 12 mode routes",
          "forkable templates instead of blank-canvas generation",
          "must-read references and deterministic validation commands"
        ],
        "quality_signals": {
          "zero_install_core": true,
          "eval_coverage_modes": 12,
          "root_skill_router": true,
          "no_required_env": true,
          "scanner_clean_scripts": true,
          "default_remote_runtime": false
        },
        "first_run_success": {
          "goal": "produce a visible HTML artifact in one turn after install",
          "required_evidence": [
            "file_path",
            "route",
            "template",
            "verification_result",
            "use_affecting_caveats"
          ],
          "forbidden_setup_work": [
            "account_login",
            "global_install",
            "export_dependency_install",
            "broad_environment_change"
          ]
        },
        "output_boundary": {
          "core_outputs": [
            "verified_html",
            "svg_or_static_companions",
            "export_ready_source_structure"
          ],
          "export_claim_rule": "Do not claim MP4, GIF, PDF, PPTX, screenshot, marketplace, or security results until the relevant command or live check has passed."
        },
        "quality_score_dimensions": [
          "Discovery",
          "Implementation",
          "Structure",
          "Expertise",
          "Security"
        ],
        "benchmark_targets": {
          "observed_on": "2026-04-29",
          "skills_sh_top10_floor_installs": 260000,
          "skills_sh_design_peer_installs": {
            "frontend-design": 348100,
            "web-design-guidelines": 284200,
            "ui-ux-pro-max": 137300
          },
          "clawhub_target": "benign VirusTotal, ClawScan, and static analysis with no suspicious banner"
        },
        "marketplace_targets": [
          "skills.sh",
          "agentskill.sh",
          "agentskills.to",
          "clawhub.ai",
          "clawskills.sh",
          "skillhub.cn"
        ],
        "requires": {
          "bins": [
            "node"
          ],
          "env": []
        },
        "capability_signals": {
          "crypto": false,
          "can_make_purchases": false,
          "requires_sensitive_credentials": false
        },
        "install": {
          "skills-cli": "npx skills add peixl/ifq-design-skills",
          "openclaw": "openclaw skills install peixl/ifq-design-skills",
          "hermes": "hermes skills install github:peixl/ifq-design-skills",
          "claude-code": "git clone https://github.com/peixl/ifq-design-skills ~/.claude/skills/ifq-design-skills",
          "shared-agents": "git clone https://github.com/peixl/ifq-design-skills ~/.agents/skills/ifq-design-skills"
        }
      }
    }
  ]
}
